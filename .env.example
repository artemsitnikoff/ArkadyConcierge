# Telegram Bot (from @BotFather)
BOT_TOKEN=

# OpenRouter — voice transcription (Gemini 2.5 Pro)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_TIMEOUT=300

# Reject voice messages longer than this many seconds.
MAX_VOICE_DURATION_SEC=600

# Claude CLI (subscription-based, no API tokens)
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_REFRESH_TOKEN=

# Access control — comma-separated Telegram IDs. Empty = allow everyone.
ALLOWED_USERS=

# HTTP API key required to call POST /api/concierge/breakdown.
# Empty = endpoint disabled (returns 503). Set a strong random string in prod.
API_KEY=

# Server
LOG_LEVEL=INFO
# plain | json  — use "json" in production with log aggregators.
LOG_FORMAT=plain
